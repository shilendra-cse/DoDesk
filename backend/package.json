{
  "name": "employee-task-manager",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run tests/unit tests/integration/health.routes.test.ts",
    "test:coverage": "vitest run tests/unit tests/integration/health.routes.test.ts --coverage",
    "test:all": "VITEST_WITH_DB=1 vitest run",
    "test:all:coverage": "VITEST_WITH_DB=1 vitest run --coverage",
    "test:watch": "vitest",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:migrate": "DATABASE_URL=postgresql://test:test@localhost:5433/dodesk_test npx prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.3.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "env-cmd": "^10.1.0",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "googleapis": "^148.0.0",
    "nodemailer": "^6.10.1",
    "open": "^10.1.1",
    "pg": "^8.14.1",
    "resend": "^4.4.1",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "nodemon": "^3.1.10",
    "prisma": "^6.12.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "healthCheck": {
    "command": [
      "CMD-SHELL",
      "curl -f http://localhost:5033/health || exit 1"
    ],
    "interval": 30,
    "timeout": 5,
    "retries": 3,
    "startPeriod": 60
  }
}
